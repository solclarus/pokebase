{
  "name": "pokemon",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts"
  ],
  "scripts": {
    "validate": "npm run validate -w @pokemon/scripts",
    "build:index": "npm run build:index -w @pokemon/scripts",
    "dev": "npm run dev -w @pokemon/api",
    "dev:web": "npm run dev -w @pokemon/web",
    "build:web": "npm run build -w @pokemon/web",
    "deploy": "npm run deploy -w @pokemon/api"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0",
    "zod": "^4.3.6"
  }
}
